# Server Configuration
PORT=5000

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/registration_db

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_here

# OTP Configuration
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3

# Password Reset Configuration
RESET_TOKEN_EXPIRY_MINUTES=15
RESET_TOKEN_MAX_ATTEMPTS=3

# SendGrid Configuration (for OTP emails)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Course Registration System

# AES-256 Encryption Configuration
ENABLE_ENCRYPTION=true
ENCRYPTION_KEY=MySecureEncryptionKey32CharLongX
ENCRYPTION_IV=MySecureIV16Char

# JWT Payload Encryption Configuration
JWT_PAYLOAD_ENCRYPTION_KEY=jwtheewuw838random32charslongkey
JWT_PAYLOAD_ENCRYPTION_IV=jwtehsu78random1
